# App
# Local:
APP_URL="http://localhost:3000"
# Production (Coolify): APP_URL="https://quickhandyquote.com"
NODE_ENV="development"

# Auth — required in production (fail-closed, no default)
AUTH_SECRET="change-me-to-a-long-random-string"

# Database (docker compose postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/handyman_invoicing?schema=public"

# Per-tenant card charging (Authorize.net / Stripe / Square / PayPal) — each
# contractor brings their OWN merchant account, entered via Settings > Payment
# processor, stored encrypted in PaymentGatewayConfig. No global payment env
# vars anymore — this key is the ONLY payments-related var, and it's the
# master key for encrypting every tenant's own credentials at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required, no dev fallback — as sensitive as the Stripe billing keys below,
# since a leak unlocks every tenant's payment secret at once.
ENCRYPTION_KEY="change-me-32-random-bytes-base64-encoded"

# Stripe — HandyQuote's own $29/mo Pro subscription billing (separate from the
# contractor's own deposit/invoice payment collection above). Required, no dev
# fallback — each local `stripe listen` session mints its own webhook secret.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."

# Email (Resend) — required in prod for estimate/invite/reset mail
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="HandyQuote <estimates@quickhandyquote.com>"

# Photo storage — Cloudflare R2 (S3-compatible). Optional; without these, photos stay as data URLs in DB.
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="handyquote-photos"
# R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
# Or custom endpoint:
# R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
