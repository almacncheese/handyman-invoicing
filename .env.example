# App
# Local:
APP_URL="http://localhost:3000"
# Production (Coolify): APP_URL="https://quickhandyquote.com"
NODE_ENV="development"

# Auth — required in production (fail-closed, no default)
AUTH_SECRET="change-me-to-a-long-random-string"

# Database (docker compose postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/handyman_invoicing?schema=public"

# Payments: mock | authorize_net (auto-mock when AuthNet keys absent in dev)
PAYMENTS_MODE="mock"
# AUTHORIZE_NET_API_LOGIN_ID=""
# AUTHORIZE_NET_TRANSACTION_KEY=""
# AUTHORIZE_NET_SANDBOX="true"
# ALLOW_MOCK_PAYMENTS="true"

# Email (Resend) — required in prod for estimate/invite/reset mail
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="HandyQuote <estimates@quickhandyquote.com>"

# Photo storage — Cloudflare R2 (S3-compatible). Optional; without these, photos stay as data URLs in DB.
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="handyquote-photos"
# R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"
# Or custom endpoint:
# R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
