generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  primaryColor     String   @default("#0f5c4c")
  logoUrl          String?
  phone            String?
  email            String?
  address          String?
  website          String?
  defaultTaxPct    Float    @default(0)
  defaultDeposit   Float    @default(30)
  defaultLaborRate Float    @default(65)
  defaultMargin    Float    @default(25)
  quotePrefix      String   @default("EST")
  nextQuoteNumber  Int      @default(1)
  termsText        String?  @db.Text
  zelleHandle      String?
  cashappCashtag   String?
  venmoHandle      String?
  plan             String    @default("trial") // trial | pro
  /// When trial access ends (null for pro / legacy). After this, send/share requires pro.
  trialEndsAt      DateTime?
  /// Platform admin can override Pro list price (cents/month). null = default $29.
  monthlyPriceCents Int?
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripeSubscriptionStatus String?
  /// event.created (unix seconds) of the last Stripe webhook actually applied — guards against out-of-order delivery
  stripeLastEventAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  users      User[]
  customers  Customer[]
  quotes     Quote[]
  invoices   Invoice[]
  payments   Payment[]
  templates  LineTemplate[]
  activities Activity[]
  paymentGatewayConfig PaymentGatewayConfig?
  savedPaymentMethods  SavedPaymentMethod[]
}

/// One active payment gateway per tenant (re-save to switch) — each contractor
/// brings their OWN merchant account (paste-your-own-API-keys model, not an
/// OAuth Connect flow). Each provider module owns its own zod schema for the
/// publicFields/secret shape — a 5th processor needs no migration, just a new
/// provider module + schema branch. See src/lib/gateway-config.ts.
model PaymentGatewayConfig {
  id           String   @id @default(cuid())
  businessId   String   @unique
  provider     String   // 'authorize_net' | 'stripe' | 'square' | 'paypal'
  sandbox      Boolean  @default(true)
  /// Non-secret, provider-shaped (e.g. {apiLoginId,clientKey} | {publishableKey}
  /// | {applicationId,locationId} | {clientId}) — safe to read back to the
  /// settings UI and to the public estimate page.
  publicFields Json
  /// AES-256-GCM-encrypted JSON blob (src/lib/crypto.ts) of the provider's
  /// secret field(s) — e.g. {transactionKey} | {secretKey} | {accessToken} |
  /// {clientSecret}. Never decrypted for display, only for charging.
  secretEnc    String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

/// Webhook idempotency ledger — Stripe redelivers events, so the event id itself
/// is the atomicity gate (insert-then-catch-unique-violation), not a pre-check.
model StripeEvent {
  id          String   @id // the Stripe event id, e.g. evt_xxx
  processedAt DateTime @default(now())
}

model User {
  id             String   @id @default(cuid())
  businessId     String
  email          String
  passwordHash   String
  name           String
  role           String   @default("owner") // owner | staff
  /// Cross-tenant platform operator (see all workspaces, price overrides)
  platformAdmin  Boolean  @default(false)
  active         Boolean  @default(true)
  /// SHA-256 of reset token (raw token only emailed once)
  passwordResetTokenHash String?
  passwordResetExpires   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, email])
  @@index([email])
}

model Customer {
  id          String   @id @default(cuid())
  businessId  String
  portalToken String?  @unique
  name        String
  email      String?
  phone      String?
  address    String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  quotes   Quote[]
  savedPaymentMethods SavedPaymentMethod[]

  @@index([businessId])
  @@index([businessId, name])
}

model SavedPaymentMethod {
  id                 String   @id @default(cuid())
  businessId         String
  customerId         String
  provider           String   // authorize_net | stripe
  providerCustomerId String   // AuthNet customerProfileId / Stripe customer id
  providerMethodId   String   // AuthNet paymentProfileId / Stripe payment_method id
  brand              String?
  last4              String?
  createdAt          DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([customerId])
}

model LineTemplate {
  id            String   @id @default(cuid())
  businessId    String
  type          String // material | labor | flat
  description   String
  costCents     Int?
  marginPercent Float?
  hours         Float?
  rateCents     Int?
  amountCents   Int?
  qty           Float?   @default(1)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Quote {
  id             String    @id @default(cuid())
  businessId     String
  customerId     String?
  number         String?
  title          String    @default("Estimate")
  jobType        String? // general | plumbing | electrical | deck | paint | roofing | other
  status         String    @default("draft") // draft|sent|viewed|accepted|declined|invoiced|paid|void
  lineItems      Json
  photos         Json      @default("[]")
  taxPercent     Float     @default(0)
  depositPercent Float     @default(30)
  subtotalCents  Int       @default(0)
  taxCents       Int       @default(0)
  totalCents     Int       @default(0)
  depositCents   Int       @default(0)
  notes          String?   @db.Text
  internalNotes  String?   @db.Text
  jobAddress     String?
  publicToken    String?   @unique
  signatureData  String?   @db.Text
  signedName     String?
  declineReason  String?
  validUntil     DateTime?
  sentAt         DateTime?
  viewedAt       DateTime?
  acceptedAt     DateTime?
  declinedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice  Invoice?

  @@unique([businessId, number])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, customerId])
}

model Invoice {
  id              String    @id @default(cuid())
  businessId      String
  quoteId         String    @unique
  number          String
  status          String    @default("open") // open|partial|paid|void
  lineItems       Json
  subtotalCents   Int
  taxCents        Int
  totalCents      Int
  depositCents    Int
  amountDueCents  Int
  amountPaidCents Int       @default(0)
  dueAt           DateTime?
  notes           String?   @db.Text
  recurring       Boolean   @default(false)
  recurInterval   String?   // weekly | monthly | quarterly | yearly
  recurNextAt     DateTime?
  recurParentId   String?
  lastReminderAt  DateTime?
  reminderCount   Int       @default(0)
  autoCharge      Boolean   @default(false)
  savedMethodId   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  quote    Quote     @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@unique([businessId, number])
  @@index([businessId])
  @@index([businessId, status])
}

/// Manual payment records (cash/check/Zelle etc.) AND real per-tenant card
/// charges (method='card', provider=one of the 4 gateways) — see
/// src/lib/card-charge.ts and src/lib/providers/*.
model Payment {
  id             String    @id @default(cuid())
  businessId     String
  invoiceId      String
  amountCents    Int
  currency       String    @default("USD")
  status         String    @default("succeeded") // pending|processing|awaiting_confirmation|succeeded|failed|void
  method         String    @default("other") // cash | check | zelle | cashapp | venmo | card | other
  idempotencyKey String    @unique
  provider       String    @default("manual") // manual | authorize_net | square | stripe | paypal
  transactionId  String?
  /// Stripe PaymentIntent id / PayPal order id for the two-and-three-phase
  /// providers — stored server-side at create-intent/create-order time, looked
  /// up during confirm/capture. NEVER supplied by the client (see
  /// card-charge.ts's cross-tenant/stale-reference protection).
  providerRef    String?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  processedAt    DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([invoiceId])
}

model Activity {
  id         String   @id @default(cuid())
  businessId String
  quoteId    String?
  invoiceId  String?
  actorType  String // user | customer | system
  actorName  String?
  action     String // created|sent|viewed|accepted|declined|invoiced|payment_recorded|voided|updated
  message    String
  meta       Json?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([businessId, quoteId])
}
